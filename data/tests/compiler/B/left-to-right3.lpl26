begin
    println (
                @show(
                    @show(
                        @show(
                            @show(
                                @show(1)
                                *
                                @show(2)
                            )
                            /
                            @show(3)
                        )
                        -
                        @show(4)
                    )
                    <
                    @show(5)
                )
                +
                @show(
                    @show(
                        @show(6)
                        >
                        @show(
                            @show(7)
                            <=
                            @show(8)
                        )
                    )
                    >=
                    @show(
                        @show(9)
                        ==
                        @show(10)
                    )
                )
            );
end

fun int @show(int x) { println(x); return x; }