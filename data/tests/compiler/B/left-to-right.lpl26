begin
    println (
                (
                    (
                        (
                            (
                                @one()
                                *
                                @two()
                            )
                            /
                            @three()
                        )
                        -
                        @four()
                    )
                    <
                    @five()
                )
                +
                (
                    (
                        @six()
                        >
                        (
                            @seven()
                            <=
                            @eight()
                        )
                    )
                    >=
                    (
                        @nine()
                        ==
                        @ten()
                    )
                )
            );
end

fun int @one() { println(1); return 1; }
fun int @two() { println(2); return 2; }
fun int @three() { println(3); return 3; }
fun int @four() { println(4); return 4; }
fun int @five() { println(5); return 5; }
fun int @six() { println(6); return 6; }
fun int @seven() { println(7); return 7; }
fun int @eight() { println(8); return 8; }
fun int @nine() { println(9); return 9; }
fun int @ten() { println(10); return 10; }