begin
    int[][] grid = new (int[])[5];
    int i = 0;
    int n;

    while (i < length(grid)) {
        grid[i] = new (int)[i+1];
        grid[i][i] = i+1;
        i = i+1;
    }
    @printGrid();
    grid = null;
    n = length(grid);
end

proc @printGrid() {
    int i = 0;
    while (i < length(grid)) {
        @printIntArray(grid[i]);
        i = i+1;
    }
}

proc @printIntArray(int[] a) {
    int i = 0;
    while (i < length(a)) {
        print(a[i]);
        printch(32);
        i = i+1;
    }
    println();
}
