begin
    println(0);
    int y = 888;
    int[] a = new (int)[1];
    a[0] = 555;
    int[] b = new (int)[1];
    b[0] = 99;
    @foo(b);
    println(a[0]);
    println(y);
end

proc @foo(int [] a) {
    {
        a[0] = 1;
        println(b[0]);
        int x = 2;
        {
            x = 3;
            int y = x;
            int x = 4;
            println(y);
            {
                int z = 6;
                int x = 7;
                println(x);
            }
            println(x);
            int z = 8;
            {
                int x = 9;
                {
                    int x = 10;
                }
                println(x);
            }
        }
        println(x);
        int y = 11;
    }
}